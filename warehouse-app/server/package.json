{
  "name": "whse01-server",
  "version": "1.0.0",
  "private": true,
  "description": "WHSE-01 lumber warehouse inventory — self-hosted server",
  "main": "server.js",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "start": "node server.js",
    "build": "esbuild src/app.jsx --bundle --loader:.jsx=jsx --jsx=automatic --minify --outfile=public/app.js",
    "test": "node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
